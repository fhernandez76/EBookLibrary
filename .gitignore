# Workspace-root .gitignore (covers all 4 top-level folders)

# ---- .NET ----
[Bb]in/
[Oo]bj/
[Oo]ut/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
*.userprefs
*.pidb
*.booproj
*.svd
*.pfx
*.publishsettings
.vs/
*.cache

# ---- .NET secrets / local config ----
appsettings.Development.json
appsettings.Local.json
secrets.json
*.userosscache
*.sln.docstates

# ---- EF Core seeder output (regeneratable) ----
Automatic/EBookLibrary/scripts/seed_data.sql
Automatic/EBookLibrary/seed_data.sql

# ---- Node / Vite / React ----
node_modules/
dist/
build/
.env
.env.local
.env.*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite/

# ---- Playwright / E2E artifacts ----
**/playwright-report/
**/test-results/
**/.playwright/

# ---- Book build artifacts (regeneratable) ----
Training/book/tmp/
Training/book/.cache/

# ---- IDE / editor ----
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
logs/

# ---- Coverage ----
coverage/
*.coverage
*.coveragexml
TestResults/
