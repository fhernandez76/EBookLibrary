@inject NavigationManager Nav
@inject AuthService AuthSvc
@inject IStringLocalizer<App> Loc
@inject IJSRuntime JS

<nav class="navbar navbar-expand-md navbar-dark sticky-top" style="background-color:#1a3c7c;">
    <div class="container-xl">
        <a class="navbar-brand fw-bold" href="/">
            📚 EBook Library
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">🏠 @Loc["nav.home"]</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/search">@Loc["nav.search"]</NavLink>
                </li>
                <AuthorizeView Roles="Admin">
                    <li class="nav-item">
                        <NavLink class="nav-link text-warning" href="/admin">@Loc["nav.admin"]</NavLink>
                    </li>
                </AuthorizeView>
            </ul>

            <ul class="navbar-nav ms-auto align-items-md-center gap-2">
                <!-- Language switcher -->
                <li class="nav-item d-flex align-items-center gap-1">
                    <button class="btn btn-sm btn-outline-light" @onclick='() => SetLanguage("en")'>EN</button>
                    <button class="btn btn-sm btn-outline-light" @onclick='() => SetLanguage("es")'>ES</button>
                </li>

                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button"
                               data-bs-toggle="dropdown">
                                👤 @context.User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><NavLink class="dropdown-item" href="/profile">@Loc["nav.profile"]</NavLink></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button class="dropdown-item text-danger" @onclick="Logout">@Loc["nav.logout"]</button></li>
                            </ul>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/login">@Loc["nav.login"]</NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="btn btn-sm btn-light text-primary fw-semibold px-3" href="/register">
                                @Loc["nav.register"]
                            </NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

@code {
    private async Task Logout()
    {
        await AuthSvc.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }

    private async Task SetLanguage(string lang)
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "BlazorCulture", lang);
        await JS.InvokeVoidAsync("location.reload");
    }
}

