@page "/admin/authors"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject CatalogService CatalogSvc
@inject HttpClient Http
@inject IStringLocalizer<App> Loc

<PageTitle>@Loc["admin.authors"] — EBook Library</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0">@Loc["admin.authors"]</h1>
    <button class="btn btn-primary" @onclick="OpenCreate">+ @Loc["common.add"]</button>
</div>

@if (_result is not null)
{
    <p class="text-muted small mb-2">@Loc["search.results_count", _result.TotalCount.ToString("N0")]</p>
}

<LoadingSpinner IsLoading="_loading" />

@if (!_loading && _result is not null)
{
    <div class="card border-0 shadow-sm overflow-hidden">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Books</th><th style="width:130px;"></th></tr>
            </thead>
            <tbody>
                @foreach (var author in _result.Items)
                {
                    <tr>
                        <td class="fw-medium">@author.Name</td>
                        <td class="text-muted">@author.BookCount</td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => OpenEdit(author)">@Loc["common.edit"]</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(author.Id, author.Name)">@Loc["common.delete"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <PaginationComponent TotalPages="_result.TotalPages" CurrentPage="_currentPage" OnPageChange="GoToPage" />
}

@if (_showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId is null ? Loc["common.add"] : Loc["common.edit"]) — @Loc["admin.authors"]</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(_modalError))
                    {
                        <div class="alert alert-danger small py-2">@_modalError</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input class="form-control" @bind="_name" @bind:event="oninput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Biography</label>
                        <textarea class="form-control" rows="3" @bind="_bio"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">@Loc["common.cancel"]</button>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @Loc["common.save"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_deleteId is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">@Loc["common.delete"]</h5>
                    <button type="button" class="btn-close" @onclick="() => _deleteId = null"></button>
                </div>
                <div class="modal-body">
                    <p>@Loc["common.confirm_delete"]</p>
                    <p class="fw-semibold">@_deleteTitle</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _deleteId = null">@Loc["common.cancel"]</button>
                    <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_saving">@Loc["common.delete"]</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<AuthorModel>? _result;
    private bool _loading = true;
    private int _currentPage = 1;

    private bool _showModal;
    private string? _editId;
    private string _name = "";
    private string? _bio;
    private bool _saving;
    private string? _modalError;
    private string? _deleteId;
    private string? _deleteTitle;

    protected override async Task OnInitializedAsync() => await LoadPage(1);
    private async Task GoToPage(int page) { _currentPage = page; await LoadPage(page); }

    private async Task LoadPage(int page)
    {
        _loading = true;
        _result = await CatalogSvc.GetAuthorsAsync(page, 20);
        _loading = false;
    }

    private void OpenCreate() { _editId = null; _name = ""; _bio = null; _modalError = null; _showModal = true; }

    private void OpenEdit(AuthorModel a)
    {
        _editId = a.Id; _name = a.Name; _bio = a.Biography; _modalError = null; _showModal = true;
    }

    private void CloseModal() { _showModal = false; _modalError = null; }

    private async Task SaveAsync()
    {
        _saving = true; _modalError = null;
        try
        {
            HttpResponseMessage resp = _editId is null
                ? await Http.PostAsJsonAsync("authors", new { name = _name, biography = _bio })
                : await Http.PutAsJsonAsync($"authors/{_editId}", new { authorId = _editId, name = _name, biography = _bio });

            if (resp.IsSuccessStatusCode) { CloseModal(); await LoadPage(_currentPage); }
            else _modalError = $"Error: {resp.StatusCode}";
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(string id, string name) { _deleteId = id; _deleteTitle = name; }

    private async Task DeleteAsync()
    {
        if (_deleteId is null) return;
        _saving = true;
        var resp = await Http.DeleteAsync($"authors/{_deleteId}");
        _deleteId = null; _saving = false;
        if (resp.IsSuccessStatusCode) await LoadPage(_currentPage);
    }
}
