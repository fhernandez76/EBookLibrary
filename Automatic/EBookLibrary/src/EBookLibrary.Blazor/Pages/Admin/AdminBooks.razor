@page "/admin/books"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject BookService BookSvc
@inject HttpClient Http
@inject IStringLocalizer<App> Loc

<PageTitle>@Loc["admin.books"] — EBook Library</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0">@Loc["admin.books"]</h1>
    <button class="btn btn-primary" @onclick="OpenCreate">+ @Loc["common.add"]</button>
</div>

<div class="d-flex gap-2 mb-3">
    <input type="text" class="form-control" style="max-width:280px;"
           placeholder="@Loc["search.filter_title"]"
           @bind="_searchTitle" @onkeydown="SearchKeyDown" />
    <button class="btn btn-primary" @onclick="Search">@Loc["home.search_btn"]</button>
</div>

@if (_result is not null)
{
    <p class="text-muted small mb-2">@Loc["search.results_count", _result.TotalCount.ToString("N0")]</p>
}

<LoadingSpinner IsLoading="_loading" />

@if (!_loading && _result is not null)
{
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th><th>Author</th><th>Genre</th>
                        <th>Pages</th><th>Status</th><th>File</th>
                        <th style="width:130px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in _result.Items)
                    {
                        <tr>
                            <td class="fw-medium" style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@book.Title</td>
                            <td class="text-muted small">@book.PrimaryAuthor</td>
                            <td><span class="badge" style="background-color:#1a3c7c;font-size:.7rem;">@book.PrimaryGenre</span></td>
                            <td class="text-muted small">@book.Pages</td>
                            <td><span class="badge @(book.Status == "Available" ? "bg-success" : "bg-secondary")">@book.Status</span></td>
                            <td>@(book.HasFile ? "✔" : "—")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => OpenEdit(book)">@Loc["common.edit"]</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(book.Id, book.Title)">@Loc["common.delete"]</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <PaginationComponent TotalPages="_result.TotalPages" CurrentPage="_currentPage" OnPageChange="GoToPage" />
}

@if (_showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId is null ? Loc["common.add"] : Loc["common.edit"]) — @Loc["admin.books"]</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(_modalError))
                    {
                        <div class="alert alert-danger small py-2">@_modalError</div>
                    }
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Title *</label>
                            <input class="form-control" @bind="_form.Title" @bind:event="oninput" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Language *</label>
                            <input class="form-control" @bind="_form.Language" @bind:event="oninput" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Pages *</label>
                            <input type="number" class="form-control" @bind="_form.Pages" min="1" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Year</label>
                            <input type="number" class="form-control" @bind="_form.PublicationYear" min="1800" max="2026" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ISBN</label>
                            <input class="form-control" @bind="_form.Isbn" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" @bind="_form.Description"></textarea>
                        </div>
                        @if (_editId is null)
                        {
                            <div class="col-md-6">
                                <label class="form-label">Author IDs (comma-separated GUIDs)</label>
                                <input class="form-control font-monospace small" placeholder="guid1, guid2" @bind="_authorIds" @bind:event="oninput" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Genre IDs (comma-separated GUIDs)</label>
                                <input class="form-control font-monospace small" placeholder="guid1, guid2" @bind="_genreIds" />
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">@Loc["common.cancel"]</button>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @Loc["common.save"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_deleteId is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">@Loc["common.delete"]</h5>
                    <button type="button" class="btn-close" @onclick="() => _deleteId = null"></button>
                </div>
                <div class="modal-body">
                    <p>@Loc["common.confirm_delete"]</p>
                    <p class="fw-semibold">@_deleteTitle</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _deleteId = null">@Loc["common.cancel"]</button>
                    <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_saving">@Loc["common.delete"]</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<BookSummary>? _result;
    private bool _loading = true;
    private int _currentPage = 1;
    private string? _searchTitle;

    private bool _showModal;
    private string? _editId;
    private bool _saving;
    private string? _modalError;
    private BookForm _form = new();
    private string? _authorIds;
    private string? _genreIds;
    private string? _deleteId;
    private string? _deleteTitle;

    private class BookForm
    {
        public string Title { get; set; } = "";
        public int Pages { get; set; } = 1;
        public int? PublicationYear { get; set; }
        public string? Isbn { get; set; }
        public string? Description { get; set; }
        public string Language { get; set; } = "English";
    }

    protected override async Task OnInitializedAsync() => await LoadPage(1);
    private async Task Search() { _currentPage = 1; await LoadPage(1); }
    private async Task GoToPage(int page) { _currentPage = page; await LoadPage(page); }
    private void SearchKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") _ = Search(); }

    private async Task LoadPage(int page)
    {
        _loading = true;
        _result = await BookSvc.SearchAsync(new BookSearchFilter(Title: _searchTitle, PageNumber: page, PageSize: 20));
        _loading = false;
    }

    private void OpenCreate() { _editId = null; _form = new(); _authorIds = null; _genreIds = null; _modalError = null; _showModal = true; }

    private void OpenEdit(BookSummary book)
    {
        _editId = book.Id;
        _form = new BookForm { Title = book.Title, Pages = book.Pages, PublicationYear = book.PublicationYear, Language = "English" };
        _modalError = null;
        _showModal = true;
    }

    private void CloseModal() { _showModal = false; _modalError = null; }

    private async Task SaveAsync()
    {
        _saving = true; _modalError = null;
        try
        {
            HttpResponseMessage resp;
            if (_editId is null)
            {
                resp = await Http.PostAsJsonAsync("books", new
                {
                    title = _form.Title, pages = _form.Pages, publicationYear = _form.PublicationYear,
                    isbn = _form.Isbn, description = _form.Description, language = _form.Language,
                    authorIds = ParseGuids(_authorIds), genreIds = ParseGuids(_genreIds)
                });
            }
            else
            {
                resp = await Http.PutAsJsonAsync($"books/{_editId}", new
                {
                    bookId = _editId, title = _form.Title, pages = _form.Pages,
                    publicationYear = _form.PublicationYear, isbn = _form.Isbn,
                    description = _form.Description, language = _form.Language
                });
            }
            if (resp.IsSuccessStatusCode) { CloseModal(); await LoadPage(_currentPage); }
            else _modalError = $"Error: {resp.StatusCode}";
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(string id, string title) { _deleteId = id; _deleteTitle = title; }

    private async Task DeleteAsync()
    {
        if (_deleteId is null) return;
        _saving = true;
        var resp = await Http.DeleteAsync($"books/{_deleteId}");
        _deleteId = null; _saving = false;
        if (resp.IsSuccessStatusCode) await LoadPage(_currentPage);
    }

    private static List<Guid> ParseGuids(string? raw) =>
        raw?.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
           .Select(s => Guid.TryParse(s, out var g) ? g : (Guid?)null)
           .Where(g => g.HasValue).Select(g => g!.Value).ToList() ?? [];
}
