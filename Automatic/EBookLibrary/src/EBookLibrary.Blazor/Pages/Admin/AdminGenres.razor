@page "/admin/genres"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject CatalogService CatalogSvc
@inject HttpClient Http
@inject IStringLocalizer<App> Loc

<PageTitle>@Loc["admin.genres"] — EBook Library</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0">@Loc["admin.genres"]</h1>
    <button class="btn btn-primary" @onclick="OpenCreate">+ @Loc["common.add"]</button>
</div>

<LoadingSpinner IsLoading="_loading" />

@if (!_loading && _genres.Count > 0)
{
    <p class="text-muted small mb-2">@_genres.Count genres</p>
    <div class="card border-0 shadow-sm overflow-hidden">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Books</th><th style="width:130px;"></th></tr>
            </thead>
            <tbody>
                @foreach (var genre in _genres)
                {
                    <tr>
                        <td class="fw-medium">@genre.Name</td>
                        <td class="text-muted">@genre.BookCount</td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => OpenEdit(genre)">@Loc["common.edit"]</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(genre.Id, genre.Name)">@Loc["common.delete"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId is null ? Loc["common.add"] : Loc["common.edit"]) — @Loc["admin.genres"]</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(_modalError))
                    {
                        <div class="alert alert-danger small py-2">@_modalError</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input class="form-control" @bind="_name" @bind:event="oninput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_description" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">@Loc["common.cancel"]</button>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @Loc["common.save"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_deleteId is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">@Loc["common.delete"]</h5>
                    <button type="button" class="btn-close" @onclick="() => _deleteId = null"></button>
                </div>
                <div class="modal-body">
                    <p>@Loc["common.confirm_delete"]</p>
                    <p class="fw-semibold">@_deleteTitle</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _deleteId = null">@Loc["common.cancel"]</button>
                    <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_saving">@Loc["common.delete"]</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<GenreModel> _genres = [];
    private bool _loading = true;

    private bool _showModal;
    private string? _editId;
    private string _name = "";
    private string? _description;
    private bool _saving;
    private string? _modalError;
    private string? _deleteId;
    private string? _deleteTitle;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _genres = await CatalogSvc.GetGenresAsync();
        _loading = false;
    }

    private void OpenCreate() { _editId = null; _name = ""; _description = null; _modalError = null; _showModal = true; }

    private void OpenEdit(GenreModel g)
    {
        _editId = g.Id; _name = g.Name; _description = g.Description; _modalError = null; _showModal = true;
    }

    private void CloseModal() { _showModal = false; _modalError = null; }

    private async Task SaveAsync()
    {
        _saving = true; _modalError = null;
        try
        {
            HttpResponseMessage resp = _editId is null
                ? await Http.PostAsJsonAsync("genres", new { name = _name, description = _description })
                : await Http.PutAsJsonAsync($"genres/{_editId}", new { genreId = _editId, name = _name, description = _description });

            if (resp.IsSuccessStatusCode) { CloseModal(); await Load(); }
            else _modalError = $"Error: {resp.StatusCode}";
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(string id, string name) { _deleteId = id; _deleteTitle = name; }

    private async Task DeleteAsync()
    {
        if (_deleteId is null) return;
        _saving = true;
        var resp = await Http.DeleteAsync($"genres/{_deleteId}");
        _deleteId = null; _saving = false;
        if (resp.IsSuccessStatusCode) await Load();
    }
}
