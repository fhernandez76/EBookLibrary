@page "/admin/users"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject CatalogService CatalogSvc
@inject HttpClient Http
@inject IStringLocalizer<App> Loc

<PageTitle>@Loc["admin.users"] — EBook Library</PageTitle>

<h1 class="fw-bold mb-4">@Loc["admin.users"]</h1>

@if (_result is not null)
{
    <p class="text-muted small mb-2">@Loc["search.results_count", _result.TotalCount.ToString("N0")]</p>
}

<LoadingSpinner IsLoading="_loading" />

@if (!_loading && _result is not null)
{
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Email</th><th>Name</th><th>Role</th><th>Active</th><th>Created</th><th style="width:200px;"></th></tr>
                </thead>
                <tbody>
                    @foreach (var user in _result.Items)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td class="text-muted">
                                @(string.IsNullOrWhiteSpace(user.FirstName) ? "—" : $"{user.FirstName} {user.LastName}")
                            </td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">@user.Role</span>
                            </td>
                            <td>@(user.IsActive ? "✔" : "—")</td>
                            <td class="text-muted small">@user.CreatedAt.ToShortDateString()</td>
                            <td class="d-flex gap-1 flex-wrap">
                                <button class="btn btn-sm btn-outline-secondary"
                                        disabled="@_toggling.Contains(user.Id)"
                                        title="@(user.Role == "Admin" ? "→ Regular" : "→ Admin")"
                                        @onclick="() => ToggleRole(user)">
                                    @(user.Role == "Admin" ? "→ Regular" : "→ Admin")
                                </button>
                                <button class="btn btn-sm @(user.IsActive ? "btn-outline-success" : "btn-outline-secondary")"
                                        disabled="@_togglingStatus.Contains(user.Id)"
                                        title="@(user.IsActive ? "Deactivate" : "Activate")"
                                        @onclick="() => ToggleStatus(user)">
                                    ⏻
                                </button>
                                <button class="btn btn-sm btn-outline-primary"
                                        title="Edit user"
                                        @onclick="() => OpenEdit(user)">
                                    ✏
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        title="Delete user"
                                        @onclick="() => ConfirmDelete(user)">
                                    🗑
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <PaginationComponent TotalPages="_result.TotalPages" CurrentPage="_currentPage" OnPageChange="GoToPage" />
}

@if (!string.IsNullOrWhiteSpace(_globalError))
{
    <div class="alert alert-danger mt-3 small">@_globalError</div>
}

@* ── Edit User Modal ──────────────────────────────────────────────────────── *@
@if (_showEditModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit User</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(_editError))
                    {
                        <div class="alert alert-danger small py-2">@_editError</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">First Name</label>
                        <input class="form-control" @bind="_editFirstName" @bind:event="oninput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Last Name</label>
                        <input class="form-control" @bind="_editLastName" @bind:event="oninput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email *</label>
                        <input class="form-control" type="email" @bind="_editEmail" @bind:event="oninput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">New Password <small class="text-muted">(leave blank to keep current)</small></label>
                        <input class="form-control" type="password" placeholder="••••••••" @bind="_editPassword" @bind:event="oninput" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseEditModal">@Loc["common.cancel"]</button>
                    <button class="btn btn-primary" @onclick="SaveEditAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @Loc["common.save"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete Confirmation Modal ─────────────────────────────────────────────── *@
@if (_deleteTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">Delete User</h5>
                    <button type="button" class="btn-close" @onclick="() => _deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p>This action is <strong>permanent</strong> and cannot be undone. The following user will be deleted:</p>
                    <p class="fw-semibold">@_deleteTarget.Email</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _deleteTarget = null">@Loc["common.cancel"]</button>
                    <button class="btn btn-danger" @onclick="DeleteAsync" disabled="@_saving">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<UserModel>? _result;
    private bool _loading = true;
    private int _currentPage = 1;
    private readonly HashSet<string> _toggling = [];
    private readonly HashSet<string> _togglingStatus = [];
    private string? _globalError;

    // Edit modal state
    private bool _showEditModal;
    private string? _editUserId;
    private string _editFirstName = "";
    private string _editLastName = "";
    private string _editEmail = "";
    private string _editPassword = "";
    private string? _editError;
    private bool _saving;

    // Delete modal state
    private UserModel? _deleteTarget;

    protected override async Task OnInitializedAsync() => await LoadPage(1);
    private async Task GoToPage(int page) { _currentPage = page; await LoadPage(page); }

    private async Task LoadPage(int page)
    {
        _loading = true;
        _result = await CatalogSvc.GetUsersAsync(page, 20);
        _loading = false;
    }

    private async Task ToggleRole(UserModel user)
    {
        _toggling.Add(user.Id);
        _globalError = null;
        var newRole = user.Role == "Admin" ? "Regular" : "Admin";
        try
        {
            var resp = await Http.PatchAsJsonAsync($"users/{user.Id}/role", new { newRole });
            if (resp.IsSuccessStatusCode)
                await LoadPage(_currentPage);
            else
                _globalError = $"Role update failed: {resp.StatusCode}";
        }
        catch (Exception ex) { _globalError = ex.Message; }
        finally { _toggling.Remove(user.Id); }
    }

    private async Task ToggleStatus(UserModel user)
    {
        _togglingStatus.Add(user.Id);
        _globalError = null;
        try
        {
            var resp = await Http.PatchAsync($"users/{user.Id}/status", null);
            if (resp.IsSuccessStatusCode)
                await LoadPage(_currentPage);
            else
                _globalError = $"Status update failed: {resp.StatusCode}";
        }
        catch (Exception ex) { _globalError = ex.Message; }
        finally { _togglingStatus.Remove(user.Id); }
    }

    private void OpenEdit(UserModel user)
    {
        _editUserId = user.Id;
        _editFirstName = user.FirstName ?? "";
        _editLastName = user.LastName ?? "";
        _editEmail = user.Email;
        _editPassword = "";
        _editError = null;
        _showEditModal = true;
    }

    private void CloseEditModal() { _showEditModal = false; _editError = null; }

    private async Task SaveEditAsync()
    {
        _saving = true; _editError = null;
        try
        {
            var resp = await Http.PutAsJsonAsync($"users/{_editUserId}", new
            {
                firstName = _editFirstName,
                lastName = _editLastName,
                email = _editEmail,
                newPassword = string.IsNullOrWhiteSpace(_editPassword) ? null : _editPassword
            });

            if (resp.IsSuccessStatusCode) { CloseEditModal(); await LoadPage(_currentPage); }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _editError = $"Error {resp.StatusCode}: {body}";
            }
        }
        catch (Exception ex) { _editError = ex.Message; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(UserModel user) { _deleteTarget = user; }

    private async Task DeleteAsync()
    {
        if (_deleteTarget is null) return;
        _saving = true;
        try
        {
            var resp = await Http.DeleteAsync($"users/{_deleteTarget.Id}");
            _deleteTarget = null;
            if (resp.IsSuccessStatusCode) await LoadPage(_currentPage);
            else _globalError = $"Delete failed: {resp.StatusCode}";
        }
        catch (Exception ex) { _globalError = ex.Message; }
        finally { _saving = false; }
    }
}

