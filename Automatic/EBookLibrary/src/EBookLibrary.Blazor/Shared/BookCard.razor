@inject NavigationManager NavigationManager

<div class="card h-100 shadow-sm border-0 book-card" style="cursor:pointer; transition: box-shadow .2s;"
     @onclick="GoToDetail">
    <!-- Cover -->
    <div class="d-flex align-items-center justify-content-center position-relative"
         style="height:180px; background: linear-gradient(135deg, #1a3c7c 0%, #0f2146 100%); border-radius:.5rem .5rem 0 0; overflow:hidden;">
        @if (!string.IsNullOrWhiteSpace(Book.CoverImageUrl))
        {
            <img src="@Book.CoverImageUrl" alt="@Book.Title" class="img-fluid h-100 w-100" style="object-fit:cover;" />
        }
        else
        {
            <span style="font-size:3.5rem;">📖</span>
        }
        <!-- Status indicator -->
        <span class="position-absolute top-0 end-0 m-1 badge @(Book.Status == "Available" ? "bg-success" : "bg-secondary")">
            @Book.Status
        </span>
    </div>

    <div class="card-body d-flex flex-column p-3">
        <span class="badge mb-2 align-self-start" style="background-color:#b0133a; font-size:.7rem;">
            @Book.PrimaryGenre
        </span>
        <h6 class="card-title fw-bold mb-1" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
            @Book.Title
        </h6>
        <p class="card-text text-muted small mb-0">@Book.PrimaryAuthor</p>
        <div class="mt-auto pt-2 d-flex justify-content-between align-items-center border-top border-light">
            <small class="text-muted">@Book.Pages pg</small>
            @if (Book.HasFile && Book.Status == "Available")
            {
                <span class="badge bg-success-subtle text-success border border-success-subtle">ePub</span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public BookSummary Book { get; set; } = null!;

    private void GoToDetail()
        => NavigationManager.NavigateTo($"/books/{Book.Id}");
}
