{
  "info": {
    "_postman_id": "ebooklibrary-api-collection-v1",
    "name": "EBook Library API",
    "description": "Complete Postman collection for the EBook Library REST API.\n\nBase URL: http://localhost:5000/api\n\nHow to use:\n1. Run the 'Admin Login' request first.\n2. The 'Admin Token' variable is set automatically via the test script.\n3. Use 'Register User' then 'User Login' to test regular-user flows.\n4. All authenticated requests read from the {{adminToken}} or {{userToken}} collection variables.\n\nSeeded Admin Credentials:\n  Email: admin@ebooklibrary.com\n  Password: Admin@12345",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:5000/api", "type": "string" },
    { "key": "adminToken", "value": "",                          "type": "string" },
    { "key": "userToken",  "value": "",                          "type": "string" },
    { "key": "bookId",     "value": "",                          "type": "string" },
    { "key": "authorId",   "value": "",                          "type": "string" },
    { "key": "genreId",    "value": "",                          "type": "string" },
    { "key": "userId",     "value": "",                          "type": "string" }
  ],
  "item": [
    {
      "name": "01 — Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.isSuccess && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('adminToken', json.data.token);",
                  "    pm.collectionVariables.set('userId', json.data.userId);",
                  "    console.log('Admin token saved.');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token present', () => pm.expect(json.data.token).to.be.a('string').and.not.empty);",
                  "pm.test('Role is Admin', () => pm.expect(json.data.role).to.eql('Admin'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ebooklibrary.com\",\n  \"password\": \"Admin@12345\"\n}"
            },
            "description": "Login as the seeded admin user. Automatically saves adminToken to collection variable."
          },
          "response": []
        },
        {
          "name": "Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.isSuccess && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('userToken', json.data.token);",
                  "    console.log('User token saved.');",
                  "}",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Role is Regular', () => pm.expect(json.data.role).to.eql('Regular'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass@123\",\n  \"confirmPassword\": \"TestPass@123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\"\n}"
            },
            "description": "Register a new regular user. Automatically saves userToken to collection variable."
          },
          "response": []
        },
        {
          "name": "User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.isSuccess && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('userToken', json.data.token);",
                  "    console.log('User token saved.');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass@123\"\n}"
            },
            "description": "Login as the regular user. Saves userToken."
          },
          "response": []
        },
        {
          "name": "Register — Validation Error (weak password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('isSuccess false', () => pm.expect(pm.response.json().isSuccess).to.be.false);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bad@example.com\",\n  \"password\": \"12345\",\n  \"confirmPassword\": \"12345\"\n}"
            },
            "description": "TC-AUTH-04 — Expect 400 due to weak password."
          },
          "response": []
        },
        {
          "name": "Login — Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ebooklibrary.com\",\n  \"password\": \"WrongPassword!\"\n}"
            },
            "description": "TC-AUTH-11 — Expect 400."
          },
          "response": []
        }
      ]
    },
