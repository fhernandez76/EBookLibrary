        <mxCell id="g12" value="&lt;b&gt;Blazor WASM SPA&lt;/b&gt;&lt;br/&gt;&lt;i&gt;[Container: Blazor WebAssembly]&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;Public-facing SPA for&lt;br/&gt;catalog browsing, auth,&lt;br/&gt;and ebook download.&lt;br/&gt;Served at port 5001." style="rounded=1;fillColor=#6a1b9a;strokeColor=#4a148c;fontColor=#ffffff;fontSize=11;fontStyle=1;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="310" y="200" width="280" height="180" as="geometry"/></mxCell>
