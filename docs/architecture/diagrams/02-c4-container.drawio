        <mxCell id="g14" value="&lt;b&gt;Web API&lt;/b&gt;&lt;br/&gt;&lt;i&gt;[Container: ASP.NET Core 10]&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;REST API.  JWT Bearer auth.&lt;br/&gt;Rate-limited auth endpoints.&lt;br/&gt;CQRS via MediatR.&lt;br/&gt;FluentValidation.&lt;br/&gt;OpenAPI + Scalar.&lt;br/&gt;Port 5000." style="rounded=1;fillColor=#1565c0;strokeColor=#0d47a1;fontColor=#ffffff;fontSize=11;fontStyle=1;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="720" y="240" width="320" height="320" as="geometry"/></mxCell>
